# ── OneTap backend configuration ───────────────────────────────────────────────
# Copy this file to ".env" and fill in your secrets there. ".env" is git-ignored.
# NEVER commit real secrets, and never put eBay secrets in the iOS app.

# eBay environment: production | sandbox
EBAY_ENV=production

# eBay PRODUCTION keyset (server-side only). Get these at https://developer.ebay.com.
# eBay shows 3 values; the Browse API uses only 2:
#   App ID (Client ID) -> EBAY_CLIENT_ID,  Cert ID (Client Secret) -> EBAY_CLIENT_SECRET.
#   Dev ID is NOT used by the Browse API (ignore it).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# Sold/completed data needs eBay Marketplace Insights API — a SEPARATE Limited Release
# approval (a standard production keyset does NOT include it). Keep false until approved;
# sold listings stay on sample data. Active listings (Browse API) work with the keyset above.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false

# Shared secret between the app and this backend. When set, /search requires
# "Authorization: Bearer <API_KEY>". Generate one with:  openssl rand -hex 32
API_KEY=

# Server
PORT=8080
HOST=0.0.0.0

# Tuning
ACTIVE_LISTINGS_LIMIT=12
CACHE_TTL_SECONDS=300
REQUEST_TIMEOUT_MS=8000
RATE_LIMIT_PER_MINUTE=60
