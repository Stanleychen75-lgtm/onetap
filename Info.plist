<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Transport Security. We deliberately do NOT set NSAllowsArbitraryLoads: production
	     traffic (the Render backend and eBay images) is HTTPS, so arbitrary public cleartext
	     stays blocked even in Release. NSAllowsLocalNetworking is the only exception — it lets
	     the app reach your Mac's backend over plain HTTP on the LAN (e.g.
	     http://10.0.130.233:8080) for local device testing, without opening the public internet
	     to cleartext. Cloudflare-tunnel and Render URLs are HTTPS and need no exception. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
