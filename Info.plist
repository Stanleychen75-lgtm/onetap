<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- LOCAL DEVELOPMENT ONLY. Allows the app to reach your Mac's backend over plain
	     HTTP on the LAN (e.g. http://10.0.130.233:8080). iOS blocks cleartext HTTP by
	     default, which is why a real device shows "Could not connect to the server".
	     Remove this whole NSAppTransportSecurity block before shipping to the App Store.
	     (All other Info.plist keys are still auto-generated by GENERATE_INFOPLIST_FILE.) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
